#!/bin/bash
# Transcriptor App - Main executable

SCRIPT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$SCRIPT_DIR"

mkdir -p audio transcriptions

open audio

DIALOG_RESULT=$(osascript -e 'display dialog "Arrastra tus archivos de audio a la carpeta que se ha abierto.

Elige el idioma del audio y pulsa el botón para iniciar la transcripción." with title "🎙️ Transcriptor" buttons {"Cancelar", "Inglés", "Español"} default button "Español" with icon note' 2>/dev/null)

if [ $? -ne 0 ]; then
    exit 0
fi

if [[ "$DIALOG_RESULT" == *"Inglés"* ]]; then
    LANGUAGE="en"
elif [[ "$DIALOG_RESULT" == *"Español"* ]]; then
    LANGUAGE="es"
else
    exit 0
fi

osascript -e "tell application \"Terminal\"
    activate
    do script \"cd '$SCRIPT_DIR' && ./venv/bin/python transcribe.py --language $LANGUAGE; echo ''; echo 'Pulsa cualquier tecla para cerrar...'; read -n 1\"
end tell"
